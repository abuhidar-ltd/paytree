// Prisma schema for Paytree - Obsidian Terminal Edition

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String  @id @default(cuid())
  email         String  @unique
  emailVerified Boolean @default(false)
  name          String?
  username      String  @unique
  bio      String?  @db.Text
  image    String?  @db.Text

  // Page status
  pageStatus  String?   @default("draft") // draft, preview, published
  publishedAt DateTime?

  // Subscription fields
  subscriptionStatus   String?   @default("free") // free, trial, active, canceled
  subscriptionPlan     String? // starter, pro
  subscriptionInterval String? // monthly, yearly
  trialEndsAt          DateTime?
  subscriptionEndsAt   DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?

  // Stripe Connect (creator direct payments)
  stripeAccountId     String?
  stripeAccountStatus String?  @default("not_connected")
  platformFeePercent  Int?     @default(8)
  // Creator's payout country (ISO 3166-1 alpha-2, e.g. "US", "AE"). Used to
  // create the Stripe Express account in the RIGHT country — omitting it makes
  // Stripe default to the PLATFORM's country (US), silently blocking non-US
  // creators' bank setup. Set once, before the connect flow fires; locked at
  // Stripe after the account is created.
  country             String?

  // Theme customization
  theme           String? @default("dark") // dark, light, custom
  primaryColor    String? @default("#3b82f6")
  backgroundColor String? @default("#0f172a")
  buttonStyle     String? @default("3d") // 3d, flat, glass
  fontFamily      String? @default("inter")

  // Enhanced customization
  backgroundStyle    String? @default("mesh") // mesh, particles, geometric, minimal, custom
  backgroundImageUrl String? @db.Text // For custom background uploads (supports data URLs)
  accentColor        String? @default("#8b5cf6")
  textColor          String? @default("#ffffff")
  socialIconPosition String? @default("bottom") // top, bottom
  heroStyle          String? @default("classic") // classic, cinematic
  heroImage          String? @db.Text           // separate cinematic hero background image
  cornerRadius       String? @default("medium") // none, small, medium, full

  // ===== OBSIDIAN TERMINAL FEATURES =====
  
  // Live Broadcast Mode
  liveStatus  Boolean @default(false)
  liveMessage String? // e.g., "TRADING ON SOLANA", "CURRENTLY LIVE"
  
  // Bento Authority Stats
  statsStudents  Int     @default(0)
  statsWinRate   Decimal @default(0) @db.Decimal(5, 2) // e.g., 98.50
  statsFollowers Int     @default(0)
  
  // Custom stat labels (optional)
  statsLabel1 String? @default("Students")
  statsLabel2 String? @default("Win Rate")
  statsLabel3 String? @default("Followers")

  // Onboarding
  onboarded Boolean @default(false)
  // How onboarding ended: "completed" | "skipped". Null = abandoned (never
  // finished) or predates this field. Set by /api/profile from the flow.
  onboardingOutcome String?

  // Manually granted (comped) plan — partnerships, support gestures, friends.
  // A comped user has subscriptionStatus="active" + subscriptionPlan set but
  // NO Stripe subscription. isComped keeps them out of MRR estimates; the
  // Stripe webhook clears these fields if the user later genuinely pays.
  // compedExpiresAt = null means lifetime. Full history lives in PlanGrantLog.
  isComped        Boolean   @default(false)
  compedReason    String?   @db.Text
  compedBy        String?
  compedExpiresAt DateTime?
  // How the comp was granted: "manual" (admin panel) | "promo" (self-serve
  // code). promoCodeId points at the redeemed PromoCode for promo comps.
  compedSource    String?
  promoCodeId     String?

  // Branding toggle (Ultra plan removes "Made with Paytree" footer)
  removeBranding Boolean @default(false)

  // AI Agent
  aiAgentEnabled  Boolean @default(true)
  aiChatSessions  Int     @default(0)
  aiChatMessages  Int     @default(0)

  // Referral / affiliate
  referralCode     String?  @unique
  referredBy       String?
  referralEarnings Int      @default(0)

  // Partner-affiliate attribution. Nullable, set at most once at signup by the
  // ptaff cookie (first-touch), never rewritten. onDelete: SetNull so removing
  // an affiliate doesn't wipe the users they brought in.
  affiliateId String?
  affiliate   Affiliate? @relation(fields: [affiliateId], references: [id], onDelete: SetNull)

  // Fraud review tag — set MANUALLY from /admin/fraud only. Never gates
  // login, features, or publishing; used for admin tracking and excluding
  // suspected duplicate accounts from collab attribution counts.
  flaggedSuspicious Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  links           Link[]
  clicks          Click[]
  views           View[]
  socialLinks     SocialLink[]
  cryptoAddresses CryptoAddress[]
  audience        Audience[]
  modules         Module[]
  products        Product[]
  bioHistories    BioHistory[]
  aiInsights      AiInsight[]
  drops           Drop[]
  blocks          Block[]
  socialProofs      SocialProof[]
  referralsGiven    Referral[] @relation("ReferrerReferrals")
  referralsReceived Referral[] @relation("ReferredReferrals")

  // Better Auth relations
  sessions Session[]
  accounts Account[]

  signupFingerprint SignupFingerprint?

  @@index([username])
  @@index([email])
  @@index([affiliateId])
}

// ===== BETTER AUTH =====
model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([token])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Link {
  id        String   @id @default(cuid())
  userId    String
  title     String
  url       String
  icon      String? // emoji or icon name
  thumbnail String? // image URL
  order     Int      @default(0)
  enabled   Boolean  @default(true)
  style     String?  @default("default") // default, gradient, glass, 3d
  cardSize  String   @default("full") // full, half, compact
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ===== LINK TYPE (smart card detection) =====
  type String @default("generic") // generic, instagram, tiktok, twitch, youtube, twitter, product

  // ===== STARRED / PRIORITY =====
  isStarred Boolean @default(false)

  // ===== SCHEDULING =====
  scheduledFrom DateTime? // show link starting from this time
  scheduledTo   DateTime? // hide link after this time

  // ===== DEEP PORTAL SYSTEM =====
  isFolder Boolean @default(false) // true = this is a folder/portal
  parentId String? // null = top-level, set = nested inside parent folder
  
  // Self-relation for nested folders
  parent   Link?  @relation("LinkHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Link[] @relation("LinkHierarchy")

  // ===== THE VAULT (GATED CONTENT) =====
  isVaultItem   Boolean @default(false)  // Is this a vault/gated item?
  isEmailLocked Boolean @default(false)  // Requires email to unlock?
  downloadUrl   String? @db.Text         // For digital downloads (PDF, presets)
  downloadName  String?                  // Display name for download
  vaultContent  String? @db.Text         // Hidden text content for vault items

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  clicks       Click[]
  vaultUnlocks Audience[] // Emails that unlocked this vault item

  @@index([userId])
  @@index([userId, order])
  @@index([parentId])
  @@index([userId, scheduledFrom, scheduledTo, enabled])
}

model Click {
  id        String   @id @default(cuid())
  linkId    String
  userId    String
  timestamp DateTime @default(now())
  userAgent String?
  referrer  String? // normalized source: direct, instagram, tiktok, twitter, youtube, facebook, google, linkedin, other
  device    String?  @default("unknown") // mobile, desktop, tablet, unknown
  country   String?

  // ===== OBSIDIAN ANALYTICS =====
  isPortalOpen Boolean @default(false) // Track portal folder opens
  isLiveClick  Boolean @default(false) // Track clicks during live status

  link Link @relation(fields: [linkId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([linkId])
  @@index([userId])
  @@index([timestamp])
  @@index([userId, device])
  @@index([userId, referrer])
}

model View {
  id        String   @id @default(cuid())
  userId    String
  timestamp DateTime @default(now())
  userAgent String?
  referrer  String? // normalized source: direct, instagram, tiktok, twitter, youtube, facebook, google, linkedin, other
  device    String?  @default("unknown") // mobile, desktop, tablet, unknown
  country   String?
  city      String?
  lat       Float?
  lng       Float?

  // ===== OBSIDIAN ANALYTICS =====
  wasLive     Boolean @default(false)  // Was user live when this view happened
  isUnique    Boolean @default(true)   // First visit from this fingerprint
  fingerprint String?                  // Browser fingerprint for unique tracking

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
  @@index([fingerprint])
  @@index([userId, device])
  @@index([userId, referrer])
}

model SocialLink {
  id        String   @id @default(cuid())
  userId    String
  platform  String // instagram, twitter, tiktok, youtube, etc.
  url       String
  order     Int      @default(0)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, order])
}

// ===== CRYPTO VAULT =====
model CryptoAddress {
  id        String   @id @default(cuid())
  userId    String
  currency  String   // "BTC", "ETH", "SOL", "USDT", etc.
  address   String
  label     String?  // e.g., "Main Wallet", "Tips"
  enabled   Boolean  @default(true)
  order     Int      @default(0)
  
  // Analytics
  copyCount Int      @default(0) // Track how many times copied
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, order])
}

// ===== AUDIENCE CRM (EMAIL CAPTURES) =====
model Audience {
  id          String   @id @default(cuid())
  userId      String
  email       String
  source      String?  // "vault", "newsletter", "manual", etc.
  capturedAt  DateTime @default(now())
  vaultItemId String?  // Which vault item triggered the capture
  
  // Optional metadata
  ipAddress   String?
  userAgent   String?
  country     String?
  
  user        User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  vaultItem   Link? @relation(fields: [vaultItemId], references: [id], onDelete: SetNull)
  
  @@unique([userId, email]) // Prevent duplicate emails per user
  @@index([userId])
  @@index([capturedAt])
  @@index([vaultItemId])
}

// ===== BENTO MODULE SYSTEM =====
model Module {
  id        String   @id @default(cuid())
  userId    String
  type      String   // youtube, tiktok, spotify, apple_music, image, twitch, social_hub, rss, vault_teaser, quick_tip, payment
  title     String?
  enabled   Boolean  @default(true)
  order     Int      @default(0)
  span      Int      @default(1) // 1=1x1, 2=2x1, 4=2x2
  config    Json     @default("{}") // Type-specific configuration
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, order])
}

// ===== DIGITAL PRODUCTS (PAYMENT MODULE) =====
model Product {
  id           String   @id @default(cuid())
  userId       String
  title        String
  description  String?  @db.Text
  price        Int      // Price in cents
  currency     String   @default("usd")
  downloadUrl  String?  @db.Text // For digital delivery
  downloadName String?
  imageUrl     String?  @db.Text
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchases Purchase[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, enabled])
}

model Purchase {
  id              String   @id @default(cuid())
  productId       String
  buyerEmail      String
  amount          Int      // Amount paid in cents
  stripeSessionId String?  @unique
  status          String   @default("pending") // pending, completed, refunded
  createdAt       DateTime @default(now())
  
  // Delivery tracking
  downloadedAt    DateTime?
  downloadCount   Int      @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([buyerEmail])
  @@index([stripeSessionId])
  @@index([status])
}

// ===== UNLOCK TOKENS (vault email verification) =====
// linkId is intentionally a free-form id — it points to either a Link.id
// or a Block.id depending on which kind of vault is being unlocked. No FK
// constraint, because PostgreSQL FKs can only reference one parent table.
// Lifecycle is short (10-min expiry), so orphan tokens age out naturally.
model LinkUnlockToken {
  id        String   @id @default(cuid())
  linkId    String
  email     String
  token     String   @unique
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([linkId, email])
  @@index([token])
  @@index([linkId])
}

// ===== AI BIO HISTORY =====
model BioHistory {
  id        String   @id @default(cuid())
  userId    String
  bio       String   @db.Text
  prompt    String?  @db.Text // what was used to generate
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

// ===== AI INSIGHTS =====
model AiInsight {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "performance", "suggestion", "warning"
  message   String   @db.Text
  metadata  Json     @default("{}")
  dismissed Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, dismissed])
}

// ===== DROPS (countdown reveal cards) =====
model Drop {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  description  String?  @db.Text
  dropAt       DateTime
  revealUrl    String?  @db.Text
  revealText   String?  @db.Text
  status       String   @default("scheduled") // scheduled | live | ended
  limitedSpots Int?
  spotsLeft    Int?
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([userId, enabled])
}

// ===== REFERRAL / AFFILIATE =====
model Referral {
  id          String    @id @default(cuid())
  referrerId  String
  referrer    User      @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  referredId  String    @unique
  referred    User      @relation("ReferredReferrals", fields: [referredId], references: [id])
  status      String    @default("pending") // "pending" | "converted"
  createdAt   DateTime  @default(now())
  convertedAt DateTime?

  @@index([referrerId])
}

// ===== SOCIAL PROOF NOTIFICATIONS =====
model SocialProof {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "vault_unlock" | "purchase" | "visit"
  message   String
  country   String?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ===== UNIFIED BLOCK SYSTEM =====
model Block {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  title         String    @default("Untitled")
  type          String    @default("link")
  enabled       Boolean   @default(true)
  position      Int       @default(0)

  url           String?
  description   String?
  thumbnail     String?

  config        Json      @default("{}")

  layout        String    @default("classic")
  style         String    @default("glass")
  size          String    @default("full")

  priority      String    @default("none")

  scheduleStart DateTime?
  scheduleEnd   DateTime?

  lockType      String    @default("none")
  lockValue     String?

  parentId      String?
  parent        Block?    @relation("BlockChildren", fields: [parentId], references: [id])
  children      Block[]   @relation("BlockChildren")

  // Modular reveal system — any card can reveal another card after its trigger fires
  revealBlockId String?
  revealBlock   Block?    @relation("BlockReveal", fields: [revealBlockId], references: [id], onDelete: SetNull)
  revealedBy    Block[]   @relation("BlockReveal")

  clickCount    Int       @default(0)
  salesCount    Int       @default(0)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([userId, enabled])
  @@index([parentId])
}

// ===== ADMIN / INTERNAL ANALYTICS =====

// One row per landing-page document request (/, /register, /login) — persisted
// twin of the `[visit]` console line in proxy.ts. Server-side ground truth for
// bot vs human traffic quality; console logs expire, these rows don't.
model Visit {
  id        String   @id @default(cuid())
  path      String
  country   String?
  bot       Boolean  @default(false)
  referrer  String?
  clickIds  String?
  ua        String?  @db.Text
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([bot, createdAt])
}

// One row per signup: IP + coarse geo (Vercel edge headers), user agent, and
// a client-side FingerprintJS device hash beaconed right after signup
// (app/api/signup-fingerprint). Written by the user.create.after auth hook —
// deviceHash lands a moment later and stays null for bots / Google OAuth /
// JS-blocked clients (itself a signal). Read by lib/fraud-detection.ts and
// /admin/fraud. FLAGGING data for manual admin review only — never used to
// block anything automatically (shared IPs are normal: carrier NAT, WiFi,
// VPNs, families).
model SignupFingerprint {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip         String?
  country    String?
  region     String?
  city       String?
  latitude   Float?
  longitude  Float?
  userAgent  String?  @db.Text
  deviceHash String?
  createdAt  DateTime @default(now())

  @@index([ip])
  @@index([deviceHash])
  @@index([city])
}

// One row per client-side signup stage beacon — persisted twin of the
// `[signup:client]` console line (app/api/signup-telemetry). Powers the
// hydration-time distribution and signup step funnel on /admin.
model SignupTelemetry {
  id        String   @id @default(cuid())
  event     String // hydrated | step_done | validation_failed | submit | submit_result
  ms        Int?
  step      String?
  ok        Boolean?
  country   String?
  ua        String?  @db.Text
  createdAt DateTime @default(now())

  @@index([event, createdAt])
  @@index([createdAt])
}

// Audit log for manually granted plans. Every grant writes a row; revoke (or
// auto-expiry) stamps revokedAt. Never deleted — accountability record of who
// got free access, from whom, and why.
model PlanGrantLog {
  id        String    @id @default(cuid())
  userId    String
  plan      String
  duration  String // 1m | 3m | 6m | 12m | lifetime
  reason    String    @db.Text
  grantedBy String
  grantedAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@index([grantedAt])
}

// ===== PROMO CODES (self-serve plan redemption) =====
//
// A promo code is a shareable string that unlocks a comped plan without
// admin involvement. Redemption writes the SAME comped columns on User and
// the SAME PlanGrantLog audit rows as manual grants (grantedBy="promo:CODE"),
// so there is one unified free-access history. Codes are never deleted —
// deactivate (active=false) preserves redemption history.
model PromoCode {
  id             String    @id @default(cuid())
  code           String    @unique
  plan           String // "pro" | "ultra"
  durationDays   Int? // null = lifetime, no expiry once redeemed
  maxRedemptions Int? // null = unlimited uses
  timesRedeemed  Int       @default(0)
  expiresAt      DateTime? // code itself stops working after this date
  active         Boolean   @default(true)
  note           String? // internal note, e.g. "TikTok giveaway"
  createdBy      String
  createdAt      DateTime  @default(now())

  redemptions PromoRedemption[]

  @@index([active, createdAt])
}

model PromoRedemption {
  id          String    @id @default(cuid())
  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id])
  userId      String
  planGranted String
  expiresAt   DateTime? // null = lifetime
  redeemedAt  DateTime  @default(now())

  @@index([promoCodeId])
  @@index([userId])
  @@index([redeemedAt])
}

// ===== PARTNER AFFILIATES =====
//
// A partner is a person/brand who drives signups through their referral link.
// slug is the URL identifier (paytree.to/?ref=<slug>). statsToken is an
// independent unguessable token — separating them lets us regenerate the
// public URL slug without breaking the partner's stats bookmark, and vice
// versa. Payouts are computed on demand from linked users' current plan
// prices; we don't cache them so retroactive commission changes just work.
model Affiliate {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  statsToken        String   @unique
  commissionPercent Decimal  @default(20) @db.Decimal(5, 2) // 0.00 – 100.00
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users     User[]
  auditLogs AffiliateAuditLog[]

  @@index([active])
}

// Audit trail for affiliate CRUD — mirrors PlanGrantLog: never deleted, admin
// email in performedBy, changes stored as JSON diff. Cascade-deletes with the
// parent affiliate; if that ever bites us (e.g. we delete an affiliate then
// want the audit history), we detach the FK before delete.
model AffiliateAuditLog {
  id          String   @id @default(cuid())
  affiliateId String
  action      String // "create" | "update" | "toggle_active" | "regenerate_slug"
  changes     Json?
  performedBy String
  performedAt DateTime @default(now())

  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([performedAt])
}
