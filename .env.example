# ─────────────────────────────────────────────────────────────────────────────
# Paytree environment variables — template. Copy to .env and fill in.
#
# GOLDEN RULE — two databases, never crossed:
#   • LOCAL (.env on your machine): DATABASE_URL must point at the
#     "paytree-test" Neon project. Dev server, Playwright, and every script
#     in scripts/ write to whatever this URL says.
#   • PRODUCTION: DATABASE_URL lives ONLY in Vercel env vars
#     (vercel.com → paytree → Settings → Environment Variables).
#     It must NEVER appear in a file on disk. lib/prisma.ts prints a loud
#     banner if a non-production process is pointed at the production endpoint.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# LOCAL DEV / TESTS: the paytree-test Neon project connection string.
# (Production's URL is set in Vercel only — see golden rule above.)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# ── Better Auth ──────────────────────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Local dev: http://localhost:3000 — production (Vercel): https://paytree.to
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optional, production-only concerns:
# BETTER_AUTH_TRUSTED_ORIGINS=""        # comma-separated extra origins
# BETTER_AUTH_COOKIE_DOMAIN=""          # e.g. ".paytree.to" for www/apex parity

# ── Google OAuth (optional — button is gated by the NEXT_PUBLIC flag) ────────
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# NEXT_PUBLIC_GOOGLE_LOGIN_ENABLED="0"  # "1" renders the Google button

# ── Stripe (subscriptions + Connect) ─────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CLIENT_ID=""
STRIPE_CONNECT_REDIRECT_URI=""
# "STARTER" is the legacy env-var name for the Pro plan (see lib/plans.ts)
STRIPE_STARTER_MONTHLY_PRICE_ID=""
STRIPE_STARTER_YEARLY_PRICE_ID=""
STRIPE_ULTRA_MONTHLY_PRICE_ID=""
STRIPE_ULTRA_YEARLY_PRICE_ID=""

# ── Services ─────────────────────────────────────────────────────────────────
RESEND_API_KEY=""                        # transactional email
ANTHROPIC_API_KEY=""                     # AI agent / bio features
YOUTUBE_API_KEY=""                       # video card oEmbed lookups
# BLOB_READ_WRITE_TOKEN=""               # Vercel Blob (prod; dev falls back to base64)

# ── Ops / admin (optional locally) ───────────────────────────────────────────
# ADMIN_EMAILS=""                        # comma-separated admin allowlist
# HEALTH_CHECK_SECRET=""                 # unlocks detailed /api/health output
# CRON_SECRET=""                         # protects /api/cron endpoints
